{
  "name": "school-system-backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:migrate": "psql -U postgres -d school_system -f database/schema.sql",
    "db:reset": "psql -U postgres -c \"DROP DATABASE IF EXISTS school_system;\" && psql -U postgres -c \"CREATE DATABASE school_system;\" && npm run db:migrate",
    "db:migrate:url": "psql \"$DATABASE_URL\" -f database/schema.sql",
    "seed:admin": "node scripts/createAdmin.js"
  },
  "keywords": ["school", "system", "api", "express"],
  "author": "",
  "license": "ISC",
  "description": "Backend API para sistema escolar",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "express-slow-down": "^1.6.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint": "^8.57.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.1.1"
  }
}
