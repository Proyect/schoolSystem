# Configuración del servidor
PORT=5051
NODE_ENV=development

# Configuración de base de datos PostgreSQL
# Opción A: usar variables separadas
DB_HOST=localhost
DB_PORT=5432
DB_NAME=school_system
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# Opción B: usar cadena de conexión (producción)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Configuración JWT
JWT_SECRET=tu_super_secret_jwt_key_aqui_cambialo_en_produccion

# Configuración del frontend (CORS)
# Puedes usar un solo origen o varios separados por coma
FRONTEND_URL=http://localhost:4001
# FRONTEND_URLS=https://tu-dominio-frontend.com,https://admin.tu-dominio.com

# Credenciales del admin para desarrollo (usadas por scripts/createAdmin.js)
# Solo para entorno local de pruebas. No usar en producción.
ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=Admin123!